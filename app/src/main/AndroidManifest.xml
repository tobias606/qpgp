<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SECURITY INVARIANTS:
         - android.permission.INTERNET is deliberately absent: the kernel
           refuses socket creation for this app. Any diff adding it is a red flag.
         - CAMERA is the ONLY permission, added solely for QR identity
           scanning. It is runtime-requested only while the scan screen is
           open, and QR content feeds the same strict parser as pasted text. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="qPGP"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.qPGP"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".ui.UnlockActivity"
            android:exported="true"
            android:excludeFromRecents="false"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.ContactsActivity" android:exported="false" />
        <activity android:name=".ui.ChatActivity" android:exported="false" />
        <activity android:name=".ui.IdentityActivity" android:exported="false" />
        <activity android:name=".ui.AddContactActivity" android:exported="false" />
        <activity android:name=".ui.EditContactActivity" android:exported="false" />
        <activity android:name=".ui.QrShowActivity" android:exported="false" />
        <activity android:name=".ui.QrScanActivity" android:exported="false" />
    </application>
</manifest>
