<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SECURITY INVARIANT: this manifest declares ZERO permissions.
         In particular android.permission.INTERNET is deliberately absent:
         the Linux kernel will refuse socket creation for this app.
         Any future diff adding a <uses-permission> line is a red flag. -->

    <application
        android:label="Kelopatra"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Kelopatra"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".ui.UnlockActivity"
            android:exported="true"
            android:excludeFromRecents="false"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.ContactsActivity" android:exported="false" />
        <activity android:name=".ui.ChatActivity" android:exported="false" />
        <activity android:name=".ui.IdentityActivity" android:exported="false" />
        <activity android:name=".ui.AddContactActivity" android:exported="false" />
    </application>
</manifest>
